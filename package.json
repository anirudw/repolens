{
  "name": "@anirudw/repolens",
  "version": "0.2.2",
  "description": "A CLI tool to visualize repository dependency graphs",
  "type": "module",
  "bin": {
    "repolens": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
